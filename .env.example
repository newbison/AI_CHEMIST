# DeepSeek API 配置
# 在 https://platform.deepseek.com/ 获取 API key
DEEPSEEK_API_KEY=your-api-key-here

# 可选：模型名（默认 deepseek-chat）
# DEEPSEEK_MODEL=deepseek-chat

# 可选：base url（默认 https://api.deepseek.com）
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# 专利数据源代理（Clash/V2Ray 本地代理）
# 默认 http://127.0.0.1:7890（Clash 默认端口）
# 设为空字符串则禁用代理（直连，国内 Google Patents 会 503）
PATENT_PROXY=http://127.0.0.1:7890
